# ── Copy this file to ".env" and adjust the values ──────────────────────────
# docker-compose automatically reads ".env" in this directory.

# Port the web app is exposed on (host side)
APP_PORT=3000

# PostgreSQL
DB_USER=sekar
DB_PASSWORD=change_this_strong_password
DB_NAME=sekar_employees
DB_PORT_EXPOSED=5432

# Auth — IMPORTANT: change the JWT secret to a long random string
JWT_SECRET=replace-with-a-long-random-secret-string

# Initial admin account (seeded on first boot if it does not exist)
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@sekarandco.in
ADMIN_PASSWORD=change_this_admin_password

# Cookies: keep "true" when serving over plain HTTP (e.g. local / LAN).
# Set to "false" when you have HTTPS/TLS in front so cookies become Secure.
FORCE_INSECURE_COOKIE=true

# ── Google Sheets mirror (OPTIONAL) ─────────────────────────────────────────
# Set ENABLED=true and provide a Sheet ID + service-account credentials.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
# Provide credentials ONE of two ways:
#  (a) path to a mounted JSON key file:
GOOGLE_SERVICE_ACCOUNT_JSON=
#  (b) OR the base64-encoded contents of the JSON key (handy for CI/secrets):
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
